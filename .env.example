# Copy to .env in the repo root. .env is not committed.

# --- Config ---
# LIRA_CONFIG=~/Lira/config.json

# --- Telegram perception (Gemma + perception_daemon) ---
TELEGRAM_BOT_TOKEN=
# TELEGRAM_PERCEPTION_ENABLED=1
# Comma-separated Telegram user ids. Empty = accept anyone who knows the bot.
# TELEGRAM_ALLOWED_USER_IDS=123456789

# --- SearXNG (web_search; docker compose in infra/) ---
# LIRA_SEARXNG_URL=http://127.0.0.1:8080
# LIRA_SEARXNG_URL_RU=http://127.0.0.1:8081

# --- HTTP proxy for embedded search (WebEngine, route "ru") and web_fetch_url ---
# HTTP_PROXY=http://127.0.0.1:3128

# --- Debug (optional) ---
# LIRA_TOOL_POLICIES_JSON=~/Lira/data/tool_policies.json
# LIRA_QWEN_EDIT_DEBUG=1
