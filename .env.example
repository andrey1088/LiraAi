# Скопируй в .env в корне репозитория. Файл .env в git не попадает.

# --- Конфиг ---
# LIRA_CONFIG=~/Lira2/config.json

# --- Telegram perception (Gemma + perception_daemon) ---
TELEGRAM_BOT_TOKEN=
# TELEGRAM_PERCEPTION_ENABLED=1
# Только эти Telegram user id (через запятую). Пусто — принимать всех, кто знает бота.
# TELEGRAM_ALLOWED_USER_IDS=123456789

# --- SearXNG (web_search; docker compose в infra/) ---
# LIRA_SEARXNG_URL=http://127.0.0.1:8080
# LIRA_SEARXNG_URL_RU=http://127.0.0.1:8081

# --- Отладка (опционально) ---
# LIRA_TOOL_POLICIES_JSON=~/Lira2/data/tool_policies.json
# LIRA_QWEN_EDIT_DEBUG=1
